{
  "root": true,
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "rules": {
    "prettier/prettier": ["error", { "printWidth": 150 }],
    "eqeqeq": ["error", "always"]
  },
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "env": {
    "es6": true,
    "node": true,
    "jest": true
  }
}
